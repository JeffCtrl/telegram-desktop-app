{
  "name": "telegram-desktop-app",
  "version": "1.0.0",
  "description": "Cross-platform Telegram-like messaging app",
  "main": "public/electron.js",
  "homepage": "./",
  "author": "JeffCtrl",
  "license": "MIT",
  "scripts": {
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "electron-start": "wait-on http://localhost:3000 && electron .",
    "electron-dev": "concurrently -k \"npm run react-start\" \"npm run electron-start\"",
    "electron-build": "npm run react-build && electron-builder",
    "start": "npm run electron-dev",
    "build": "npm run electron-build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "axios": "^1.6.0",
    "firebase": "^10.0.0",
    "lucide-react": "^0.263.1",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.0.0",
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.24",
    "autoprefixer": "^10.4.14",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "concurrently": "^8.2.1",
    "wait-on": "^7.0.1",
    "cross-env": "^7.0.3"
  },
  "build": {
    "appId": "com.telegram.desktop",
    "productName": "Telegram Desktop",
    "files": [
      "build/**/*",
      "public/electron.js"
    ]
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
  }
}
